{
  "version": 2,

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/provider-games/:provider",
      "destination": "/assets/provider-games/:provider.json"
    },
    {
      "source": "/user/login-form",
      "destination": "/user/login-form/index.html"
    },
    {
      "source": "/user/register-form",
      "destination": "/user/register-form/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/draw",
      "schedule": "0 0 * * *"
    }
  ]
}
